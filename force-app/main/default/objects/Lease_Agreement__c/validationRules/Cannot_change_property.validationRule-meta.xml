<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Cannot_change_property</fullName>
    <active>true</active>
    <description>Cannot change property after Lease creation</description>
    <errorConditionFormula>NOT(ISNEW()) &amp;&amp;  ISCHANGED( Property__c )</errorConditionFormula>
    <errorDisplayField>Property__c</errorDisplayField>
    <errorMessage>Cannot change property after Lease creation</errorMessage>
</ValidationRule>
