<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Image_required</fullName>
    <active>true</active>
    <description>Image is required.</description>
    <errorConditionFormula>NOT(
    CONTAINS(Image__c, &apos;&lt;img&apos;)
)</errorConditionFormula>
    <errorDisplayField>Image__c</errorDisplayField>
    <errorMessage>Please upload image of the property.</errorMessage>
</ValidationRule>
