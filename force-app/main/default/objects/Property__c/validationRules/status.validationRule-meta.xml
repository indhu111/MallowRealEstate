<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>status</fullName>
    <active>true</active>
    <errorConditionFormula>AND(ISPICKVAL(Status__c ,&apos;Available&apos;), NOT(ISBLANK(Tenant__c))) ||
AND(ISPICKVAL(Status__c , &apos;Occupied&apos;), ISBLANK(Tenant__c ))</errorConditionFormula>
    <errorMessage>Change the status or remove the Tenant value.</errorMessage>
</ValidationRule>
